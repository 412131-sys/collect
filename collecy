import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getAuth, 
  signInWithPopup, 
  GoogleAuthProvider, 
  onAuthStateChanged, 
  signOut,
  signInWithCustomToken,
  signInAnonymously
} from 'firebase/auth';
import { 
  getFirestore, 
  collection, 
  addDoc, 
  onSnapshot, 
  query, 
  serverTimestamp 
} from 'firebase/firestore';
import { 
  Folder, Tag, Search, LayoutGrid, List, Plus, 
  Settings2, Camera, Watch, CreditCard, Book, 
  Palette, LogOut, User, Image as ImageIcon, Loader2
} from 'lucide-react';

// Firebase 配置
const firebaseConfig = {
  apiKey: "AIzaSyDkCpOYvK9QTLhk23f9bRYYi94nhU-hOfg",
  authDomain: "collection-b098f.firebaseapp.com",
  projectId: "collection-b098f",
  storageBucket: "collection-b098f.firebasestorage.app",
  messagingSenderId: "432081588061",
  appId: "1:432081588061:web:eecb14c970dfbb6935e2b4"
};

// 初始化 Firebase
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const googleProvider = new GoogleAuthProvider();
const appId = typeof __app_id !== 'undefined' ? __app_id : 'collection-app';

const App = () => {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const [activeTab, setActiveTab] = useState('全部');
  const [searchQuery, setSearchQuery] = useState('');
  const [items, setItems] = useState([]);
  const [isAdding, setIsAdding] = useState(false);
  
  // 新增收藏的狀態
  const [newTitle, setNewTitle] = useState('');
  const [newCategory, setNewCategory] = useState('其他');
  const [imageBase64, setImageBase64] = useState('');

  const categories = [
    { id: 'all', name: '全部', icon: <Tag size={18} /> },
    { id: 'camera', name: '攝影器材', icon: <Camera size={18} /> },
    { id: 'watch', name: '腕錶', icon: <Watch size={18} /> },
    { id: 'cards', name: '集換式卡牌', icon: <CreditCard size={18} /> },
    { id: 'books', name: '珍稀書籍', icon: <Book size={18} /> },
    { id: 'art', name: '藝術品', icon: <Palette size={18} /> },
    { id: 'others', name: '其他', icon: <Tag size={18} /> },
  ];

  // 1. 初始化驗證 (修正後的 RULE 3)
  useEffect(() => {
    const initAuth = async () => {
      try {
        // 優先嘗試使用環境提供的 token
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          try {
            await signInWithCustomToken(auth, __initial_auth_token);
          } catch (tokenErr) {
            // 如果 token 失敗（例如 mismatch），則嘗試匿名登入作為後備
            console.warn("Custom token failed, falling back to anonymous:", tokenErr);
            await signInAnonymously(auth);
          }
        } else {
          // 若無 token 則使用匿名登入
          await signInAnonymously(auth);
        }
      } catch (err) {
        console.error("Critical Auth error:", err);
      } finally {
        setLoading(false);
      }
    };

    initAuth();

    const unsubscribe = onAuthStateChanged(auth, (currentUser) => {
      setUser(currentUser);
    });

    return () => unsubscribe();
  }, []);

  // 2. 監聽 Firestore 數據 (遵循 RULE 1 & 2)
  useEffect(() => {
    // 必須有使用者且驗證完成才啟動監聽
    if (!user) {
      setItems([]);
      return;
    }

    // 使用規範路徑: /artifacts/{appId}/users/{userId}/items
    const itemsCol = collection(db, 'artifacts', appId, 'users', user.uid, 'items');
    
    // 簡單查詢，不使用過濾以避免 index 需求
    const unsubscribe = onSnapshot(itemsCol, (snapshot) => {
      const data = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      }));
      setItems(data);
    }, (error) => {
      console.error("Firestore loading error:", error);
    });

    return () => unsubscribe();
  }, [user]);

  // 處理圖片轉 Base64
  const handleImageChange = (e) => {
    const file = e.target.files[0];
    if (file) {
      // 限制圖片大小避免 Base64 過長（可選優化）
      if (file.size > 1024 * 1024) {
        alert("圖片太大，請選擇 1MB 以下的檔案");
        return;
      }
      const reader = new FileReader();
      reader.onloadend = () => setImageBase64(reader.result);
      reader.readAsDataURL(file);
    }
  };

  // 登入
  const handleLogin = () => signInWithPopup(auth, googleProvider);

  // 登出
  const handleLogout = () => signOut(auth);

  // 新增至資料庫
  const handleAddItem = async (e) => {
    e.preventDefault();
    if (!user || !newTitle) return;

    try {
      const itemsCol = collection(db, 'artifacts', appId, 'users', user.uid, 'items');
      await addDoc(itemsCol, {
        title: newTitle,
        category: newCategory,
        image: imageBase64,
        createdAt: serverTimestamp()
      });
      // 清空狀態
      setNewTitle('');
      setImageBase64('');
      setIsAdding(false);
    } catch (err) {
      console.error("Save to Firestore error:", err);
    }
  };

  // 在前端進行過濾 (遵循 RULE 2)
  const filteredItems = items.filter(item => {
    const matchesTab = activeTab === '全部' || item.category === activeTab;
    const matchesSearch = item.title.toLowerCase().includes(searchQuery.toLowerCase());
    return matchesTab && matchesSearch;
  });

  if (loading) {
    return (
      <div className="h-screen flex items-center justify-center bg-[#F8F9FD]">
        <div className="flex flex-col items-center gap-4">
          <Loader2 className="animate-spin text-[#5B50E6]" size={40} />
          <p className="text-slate-400 animate-pulse">正在載入收藏庫...</p>
        </div>
      </div>
    );
  }

  // 判斷是否為「正式使用者」（排除匿名使用者）
  const isAnonymous = user?.isAnonymous;

  // 如果完全沒登入，或是匿名狀態下顯示登入畫面（這裡可根據需求調整，目前我們允許匿名查看空狀態）
  if (!user) {
    return (
      <div className="h-screen flex flex-col items-center justify-center bg-[#F8F9FD] p-6 text-center">
        <div className="w-16 h-16 bg-[#5B50E6] rounded-2xl flex items-center justify-center mb-6 shadow-xl shadow-indigo-100">
          <Folder className="text-white" size={32} fill="currentColor" />
        </div>
        <h1 className="text-3xl font-bold text-slate-800 mb-2">雲端收藏庫</h1>
        <p className="text-slate-500 mb-8 max-w-xs">您的數位珍藏管家，安全、快速且優雅。</p>
        <button 
          onClick={handleLogin}
          className="flex items-center gap-3 bg-white border border-slate-200 px-8 py-3 rounded-xl font-medium shadow-sm hover:shadow-md transition-all active:scale-95"
        >
          <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" className="w-5 h-5" alt="google" />
          使用 Google 帳號登入
        </button>
      </div>
    );
  }

  return (
    <div className="flex h-screen bg-[#F8F9FD] text-slate-700 font-sans">
      {/* 側邊導覽欄 */}
      <aside className="w-64 bg-white border-r border-slate-100 flex flex-col">
        <div className="p-6 flex items-center gap-3">
          <div className="w-10 h-10 bg-[#5B50E6] rounded-xl flex items-center justify-center shadow-lg shadow-indigo-200">
            <Folder className="text-white" size={20} fill="currentColor" />
          </div>
          <h1 className="text-xl font-bold tracking-tight text-slate-800">雲端收藏庫</h1>
        </div>

        <div className="px-4 mt-4 flex-1">
          <div className="flex items-center justify-between px-3 py-2 text-xs font-semibold text-slate-400 uppercase tracking-wider">
            <span>分類項目</span>
            <Settings2 size={14} className="cursor-pointer hover:text-slate-600" />
          </div>
          <nav className="mt-2 space-y-1">
            {categories.map((cat) => (
              <button
                key={cat.id}
                onClick={() => setActiveTab(cat.name)}
                className={`w-full flex items-center justify-between px-3 py-2.5 rounded-xl transition-all ${
                  activeTab === cat.name ? 'bg-[#EEEDFF] text-[#5B50E6]' : 'text-slate-500 hover:bg-slate-50'
                }`}
              >
                <div className="flex items-center gap-3">
                  <span className={activeTab === cat.name ? 'text-[#5B50E6]' : 'text-slate-400'}>{cat.icon}</span>
                  <span className="font-medium text-sm">{cat.name}</span>
                </div>
                <span className={`text-xs px-2 py-0.5 rounded-full ${
                  activeTab === cat.name ? 'bg-white text-[#5B50E6]' : 'bg-slate-100 text-slate-400'
                }`}>
                  {cat.name === '全部' 
                    ? items.length 
                    : items.filter(i => i.category === cat.name).length}
                </span>
              </button>
            ))}
          </nav>
        </div>

        {/* 使用者資訊區塊 */}
        <div className="p-4 border-t border-slate-100">
          <div className="flex items-center gap-3 p-2 bg-slate-50 rounded-xl">
            {isAnonymous ? (
              <div className="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-slate-400">
                <User size={16} />
              </div>
            ) : (
              <img src={user.photoURL} className="w-8 h-8 rounded-full border border-white shadow-sm" alt="profile" />
            )}
            
            <div className="flex-1 min-w-0">
              <p className="text-xs font-bold truncate">
                {isAnonymous ? '訪客身分' : user.displayName}
              </p>
              <p className="text-[10px] text-slate-400 truncate font-mono">
                {isAnonymous ? '尚未登入帳號' : '已登入'}
              </p>
            </div>
            
            {isAnonymous ? (
              <button onClick={handleLogin} className="text-[#5B50E6] hover:scale-110 transition-transform">
                <Plus size={16} />
              </button>
            ) : (
              <button onClick={handleLogout} className="text-slate-400 hover:text-red-500 transition-colors">
                <LogOut size={16} />
              </button>
            )}
          </div>
        </div>
      </aside>

      {/* 主要內容區 */}
      <main className="flex-1 flex flex-col min-w-0 overflow-hidden">
        <header className="h-20 bg-white border-b border-slate-100 flex items-center justify-between px-8 gap-6">
          <div className="relative w-full max-w-xl">
            <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" size={18} />
            <input
              type="text"
              placeholder="搜尋資料庫中的收藏..."
              className="w-full bg-[#F1F4F9] border-none rounded-xl py-2.5 pl-12 pr-4 text-sm focus:ring-2 focus:ring-[#5B50E6]/20 outline-none"
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
            />
          </div>
          <button 
            onClick={() => setIsAdding(true)}
            className="flex-shrink-0 flex items-center gap-2 bg-[#5B50E6] text-white px-5 py-2.5 rounded-xl font-medium shadow-lg shadow-indigo-100 hover:bg-[#4A40D0] transition-all active:scale-95"
          >
            <Plus size={18} />
            <span>新增收藏</span>
          </button>
        </header>

        <div className="flex-1 p-8 overflow-y-auto">
          <div className="mb-8 flex justify-between items-end">
            <div>
              <h2 className="text-2xl font-bold text-slate-800">{activeTab}</h2>
              <p className="text-sm text-slate-400 mt-1">
                {isAnonymous ? '請登入帳號以開始儲存資料' : `顯示 ${filteredItems.length} 項結果`}
              </p>
            </div>
            {!isAnonymous && (
              <div className="text-xs text-slate-300 font-mono">UID: {user.uid}</div>
            )}
          </div>

          {filteredItems.length === 0 ? (
            <div className="w-full aspect-[16/9] max-h-[500px] bg-white rounded-[32px] border-2 border-dashed border-slate-100 flex flex-col items-center justify-center p-12 text-center">
              <div className="w-20 h-20 bg-[#F1F4F9] rounded-full flex items-center justify-center mb-6">
                <Folder size={32} className="text-[#5B50E6]/30" fill="currentColor" />
              </div>
              <h3 className="text-xl font-bold text-slate-800 mb-2">這裡目前沒有任何收藏</h3>
              <p className="text-slate-400 max-w-xs mb-8">目前的分類下沒有資料。點擊按鈕寫入第一筆收藏。</p>
              <button 
                onClick={() => setIsAdding(true)} 
                className="bg-[#5B50E6] text-white px-8 py-3 rounded-xl font-bold shadow-xl shadow-indigo-100 hover:scale-105 transition-transform"
              >
                立即寫入資料
              </button>
            </div>
          ) : (
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
              {filteredItems.map(item => (
                <div key={item.id} className="bg-white p-4 rounded-2xl shadow-sm border border-slate-50 group hover:shadow-md transition-all">
                  <div className="aspect-square bg-slate-100 rounded-xl mb-4 overflow-hidden relative">
                    {item.image ? (
                      <img src={item.image} className="w-full h-full object-cover transition-transform group-hover:scale-105" alt={item.title} />
                    ) : (
                      <div className="w-full h-full flex items-center justify-center text-slate-300">
                        <ImageIcon size={40} />
                      </div>
                    )}
                    <div className="absolute top-2 right-2 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-lg text-[10px] font-bold text-[#5B50E6] shadow-sm">
                      {item.category}
                    </div>
                  </div>
                  <h4 className="font-bold text-slate-800 truncate">{item.title}</h4>
                  <p className="text-xs text-slate-400 mt-1">
                    {item.createdAt?.toDate ? item.createdAt.toDate().toLocaleDateString() : '剛剛'}
                  </p>
                </div>
              ))}
            </div>
          )}
        </div>
      </main>

      {/* 新增彈窗 */}
      {isAdding && (
        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center p-6">
          <div className="bg-white w-full max-w-md rounded-[32px] p-8 shadow-2xl animate-in fade-in zoom-in duration-300">
            <h3 className="text-2xl font-bold text-slate-800 mb-6">新增收藏項目</h3>
            
            {isAnonymous ? (
              <div className="p-4 bg-amber-50 border border-amber-100 rounded-xl mb-6">
                <p className="text-sm text-amber-700 leading-relaxed">
                  <strong>提醒：</strong>您目前以訪客身分瀏覽。雖然可以暫時新增資料，但為了永久保存您的珍貴收藏，建議點擊下方按鈕使用 Google 登入。
                </p>
                <button 
                  onClick={handleLogin}
                  className="mt-3 w-full bg-white border border-amber-200 py-2 rounded-lg text-sm font-bold text-amber-800 hover:bg-amber-100 transition-colors"
                >
                  切換至帳號登入
                </button>
              </div>
            ) : null}

            <form onSubmit={handleAddItem} className="space-y-5">
              <div>
                <label className="block text-sm font-bold mb-2 text-slate-600">收藏品名稱</label>
                <input 
                  autoFocus
                  required
                  className="w-full bg-slate-50 border-none rounded-xl p-3 outline-none focus:ring-2 focus:ring-[#5B50E6]/20 transition-all"
                  placeholder="例如：Rolex Submariner..."
                  value={newTitle}
                  onChange={(e) => setNewTitle(e.target.value)}
                />
              </div>
              
              <div>
                <label className="block text-sm font-bold mb-2 text-slate-600">所屬分類</label>
                <div className="relative">
                  <select 
                    className="w-full bg-slate-50 border-none rounded-xl p-3 outline-none focus:ring-2 focus:ring-[#5B50E6]/20 appearance-none cursor-pointer"
                    value={newCategory}
                    onChange={(e) => setNewCategory(e.target.value)}
                  >
                    {categories.filter(c => c.id !== 'all').map(c => (
                      <option key={c.id} value={c.name}>{c.name}</option>
                    ))}
                  </select>
                  <div className="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                    <Settings2 size={16} />
                  </div>
                </div>
              </div>

              <div>
                <label className="block text-sm font-bold mb-2 text-slate-600">上傳圖片</label>
                <div className="relative group">
                  <input 
                    type="file" 
                    accept="image/*"
                    onChange={handleImageChange}
                    className="absolute inset-0 opacity-0 cursor-pointer z-10"
                  />
                  <div className="w-full h-32 bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl flex flex-col items-center justify-center group-hover:bg-slate-100 group-hover:border-[#5B50E6]/30 transition-all overflow-hidden relative">
                    {imageBase64 ? (
                      <div className="w-full h-full relative">
                        <img src={imageBase64} className="w-full h-full object-cover" alt="preview" />
                        <div className="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity">
                          <span className="text-white text-xs font-bold bg-black/40 px-3 py-1 rounded-full">點擊更換</span>
                        </div>
                      </div>
                    ) : (
                      <>
                        <ImageIcon className="text-slate-300 mb-2 group-hover:text-[#5B50E6]/40 transition-colors" size={28} />
                        <span className="text-xs text-slate-400 font-medium">點擊或拖放圖片</span>
                        <span className="text-[10px] text-slate-300 mt-1">建議小於 1MB</span>
                      </>
                    )}
                  </div>
                </div>
              </div>

              <div className="flex gap-4 pt-4">
                <button 
                  type="button" 
                  onClick={() => setIsAdding(false)}
                  className="flex-1 py-3 font-bold text-slate-400 hover:text-slate-600 transition-colors"
                >
                  取消
                </button>
                <button 
                  type="submit"
                  className="flex-1 bg-[#5B50E6] text-white py-3 rounded-xl font-bold shadow-lg shadow-indigo-100 hover:bg-[#4A40D0] active:scale-95 transition-all"
                >
                  確認新增
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
};

export default App;
